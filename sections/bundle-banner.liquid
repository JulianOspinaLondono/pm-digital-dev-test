{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
  assign bg_desktop = section.settings.background_image_desktop
  assign bg_mobile = section.settings.background_image_mobile
  assign highlight_color = section.settings.highlight_color
%}

<section
  class="bundle-banner"
  id="bundle-banner-{{ section.id }}"
  style="--bundle-banner-highlight: {{ highlight_color }};"
>
  {%- if bg_desktop != blank -%}
    <picture class="bundle-banner__bg">
      {%- if bg_mobile != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="
            {{ bg_mobile | image_url: width: 390 }} 390w,
            {{ bg_mobile | image_url: width: 600 }} 600w,
            {{ bg_mobile | image_url: width: 780 }} 780w
          "
          sizes="100vw"
        >
      {%- endif -%}
      <img
        src="{{ bg_desktop | image_url: width: 1920 }}"
        srcset="
          {{ bg_desktop | image_url: width: 1200 }} 1200w,
          {{ bg_desktop | image_url: width: 1440 }} 1440w,
          {{ bg_desktop | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt=""
        loading="eager"
        fetchpriority="high"
        width="{{ bg_desktop.width }}"
        height="{{ bg_desktop.height }}"
      >
    </picture>
  {%- endif -%}

  <div class="bundle-banner__content">
    {% if heading != blank %}
      <h2 class="bundle-banner__heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="bundle-banner__subheading">{{ subheading }}</p>
    {% endif %}

    {% if cta_label != blank and cta_link != blank %}
      <a href="{{ cta_link }}" class="bundle-banner__cta">
        {{ cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  /* ==========================================================================
     Bundle Banner — Hero with background image
     Mobile first. Background contains gradient + product imagery.
     Text is overlaid on the left side.
     ========================================================================== */

  .bundle-banner {
    position: relative;
    overflow: hidden;
    background: #082D35;
    color: #fff;
  }

  /* Background image — full cover, contains gradient + products */
  .bundle-banner__bg {
    display: block;
    width: 100%;
  }

  .bundle-banner__bg img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Text overlay — positioned over the background */
  .bundle-banner__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--gap-sm);
    max-width: var(--page-content-width);
    margin-inline: auto;
    padding: 0 var(--page-margin) 32px;
  }

  .bundle-banner__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-style: var(--font-heading--style);
    font-size: clamp(1.375rem, 5vw, 2.625rem);
    line-height: 1.3;
    color: #fff;
    margin: 0;
    max-width: 500px;
  }

  .bundle-banner__heading em {
    font-style: normal;
    color: var(--bundle-banner-highlight, #00BCDD);
  }

  .bundle-banner__subheading {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: var(--font-size--xs);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    max-width: 400px;
  }

  .bundle-banner__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 32px;
    border: 1px solid #fff;
    border-radius: var(--style-border-radius-buttons-primary, 14px);
    color: #fff;
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    width: fit-content;
    margin-top: var(--margin-xs);
  }

  .bundle-banner__cta:hover {
    background-color: #fff;
    color: #03334D;
  }

  /* ==========================================================================
     Desktop (min-width: 750px)
     ========================================================================== */

  @media screen and (min-width: 750px) {
    .bundle-banner__content {
      justify-content: center;
      padding: 0 var(--page-margin);
      gap: var(--gap-lg);
    }

    .bundle-banner__heading {
      max-width: 480px;
    }

    .bundle-banner__subheading {
      font-size: var(--font-size--sm);
      max-width: 420px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Banner",
  "tag": "section",
  "class": "bundle-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Smart stack, smarter price - shop curated bundles and <em>save 30%.</em>"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clinically informed formulas that support energy, balance, and everyday wellness."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Bundles"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image (desktop)",
      "info": "Includes gradient and product imagery. Recommended: 1920×600px"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Different composition for small screens. Recommended: 780×900px"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight text color",
      "default": "#00BCDD"
    }
  ],
  "presets": [
    {
      "name": "Bundle Banner"
    }
  ]
}
{% endschema %}
