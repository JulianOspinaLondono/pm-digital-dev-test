{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
  assign product_image = section.settings.product_image
  assign product_image_mobile = section.settings.product_image_mobile
  assign highlight_color = section.settings.highlight_color
%}

<section
  class="bundle-banner"
  id="bundle-banner-{{ section.id }}"
  style="
    --bundle-banner-highlight: {{ highlight_color }};
    {% if product_image != blank %}
      --bundle-banner-product-desktop: url('{{ product_image | image_url: width: 1200 }}');
    {% endif %}
    {% if product_image_mobile != blank %}
      --bundle-banner-product-mobile: url('{{ product_image_mobile | image_url: width: 780 }}');
    {% endif %}
  "
>
  <div class="bundle-banner__content">
    {% if heading != blank %}
      <h2 class="bundle-banner__heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="bundle-banner__subheading">{{ subheading }}</p>
    {% endif %}

    {% if cta_label != blank and cta_link != blank %}
      <a href="{{ cta_link }}" class="bundle-banner__cta">
        {{ cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  /* ==========================================================================
     Bundle Banner — Hero with CSS gradient + product image
     Mobile first.
     ========================================================================== */

  .bundle-banner {
    position: relative;
    overflow: hidden;
    color: #fff;

    /* Gradient background */
    background:
      radial-gradient(ellipse at 60% 0%, rgba(0, 188, 221, 0.2) 0%, transparent 50%),
      linear-gradient(to bottom, #0B3039 0%, #082D35 100%);

    /* Product image as positioned background on the right */
    background-image:
      var(--bundle-banner-product-mobile, none),
      radial-gradient(ellipse at 50% 0%, rgba(0, 188, 221, 0.2) 0%, transparent 50%),
      linear-gradient(to bottom, #0B3039 0%, #082D35 100%);
    background-position: center top, center top, center;
    background-size: 90% auto, 100% 100%, 100% 100%;
    background-repeat: no-repeat;

    /* Mobile: taller to fit products on top + text below */
    min-height: 580px;
    display: flex;
    align-items: flex-end;
  }

  /* --- Text content --- */

  .bundle-banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    max-width: var(--page-content-width);
    width: 100%;
    margin-inline: auto;
    padding: 0 var(--page-margin) 32px;
  }

  .bundle-banner__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-style: var(--font-heading--style);
    font-size: clamp(1.375rem, 5vw, 2.625rem);
    line-height: 1.3;
    color: #fff;
    margin: 0;
    max-width: 500px;
  }

  .bundle-banner__heading em {
    font-style: normal;
    color: var(--bundle-banner-highlight, #00BCDD);
  }

  .bundle-banner__subheading {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: var(--font-size--xs);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    max-width: 400px;
  }

  .bundle-banner__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 32px;
    border: 1px solid #fff;
    border-radius: var(--style-border-radius-buttons-primary, 14px);
    color: #fff;
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    width: fit-content;
    margin-top: var(--margin-xs);
  }

  .bundle-banner__cta:hover {
    background-color: #fff;
    color: #03334D;
  }

  /* ==========================================================================
     Desktop (min-width: 750px)
     ========================================================================== */

  @media screen and (min-width: 750px) {
    .bundle-banner {
      /* Desktop: product image on the right side */
      background-image:
        var(--bundle-banner-product-desktop, none),
        radial-gradient(ellipse at 60% 0%, rgba(0, 188, 221, 0.18) 0%, transparent 50%),
        linear-gradient(to bottom, #0B3039 0%, #082D35 100%);
      background-position: right bottom, center top, center;
      background-size: 55% auto, 100% 100%, 100% 100%;
      background-repeat: no-repeat;

      min-height: 480px;
      align-items: center;
    }

    .bundle-banner__content {
      padding: 60px var(--page-margin);
      max-width: var(--page-content-width);
      gap: var(--gap-lg);
    }

    .bundle-banner__heading {
      max-width: 480px;
    }

    .bundle-banner__subheading {
      font-size: var(--font-size--sm);
      max-width: 420px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Banner",
  "tag": "section",
  "class": "bundle-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Smart stack, smarter price - shop curated bundles and <em>save 30%.</em>"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clinically informed formulas that support energy, balance, and everyday wellness."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Bundles"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Product imagery"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (desktop)",
      "info": "Positioned on the right side. PNG with transparent background recommended."
    },
    {
      "type": "image_picker",
      "id": "product_image_mobile",
      "label": "Product image (mobile)",
      "info": "Positioned at the top. PNG with transparent background recommended."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight text color",
      "default": "#00BCDD"
    }
  ],
  "presets": [
    {
      "name": "Bundle Banner"
    }
  ]
}
{% endschema %}
